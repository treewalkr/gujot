# Shared configuration across services (ADR-0009 / PRD #1).
# Copy to .env and adjust. Services read their own subset.

# Backend (Elysia on Bun)
BACKEND_PORT=3000

# Postgres via Supabase (ADR-0004). Two connection strings:
#   - pooled runtime (Supavisor/pgBouncer, transaction mode, port 6543) for the app
#   - direct/session mode (port 5432) for Drizzle Kit migrations only
# Against a plain local Postgres (ADR-0004 fallback) both can point at the same URL.
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL_DIRECT=postgresql://user:password@host:5432/postgres

# Where the backend is reachable. Same within the host (mode 1) and the
# compose network (mode 2: http://backend:3000).
BACKEND_URL=http://localhost:3000

# Frontend (SvelteKit, Node adapter). Default 5173 to avoid colliding with the
# backend on the host in mode-1 (partial) dev.
FRONTEND_PORT=5173
# The origin SvelteKit is served from (adapter-node ORIGIN env).
ORIGIN=http://localhost:5173
